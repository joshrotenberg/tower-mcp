{
  "mcpServers": {
    "tower-mcp-example": {
      "command": "cargo",
      "args": ["run", "-p", "tower-mcp", "--example", "getting_started"],
      "env": {
        "RUST_LOG": "tower_mcp=debug"
      }
    },
    "weather": {
      "command": "cargo",
      "args": ["run", "-p", "tower-mcp", "--example", "weather_server"],
      "env": {
        "RUST_LOG": "tower_mcp=info"
      }
    },
    "codegen-mcp": {
      "command": "cargo",
      "args": ["run", "-p", "codegen-mcp"],
      "env": {
        "RUST_LOG": "codegen_mcp=info"
      }
    }
  }
}
